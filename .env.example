# Optional overrides for self-hosted UptimeBuddy.
# Copy to `.env` only if you need to change defaults; docker-compose.yaml
# already contains working values, so the stack runs WITHOUT this file.

# Ports
APP_PORT=3000
KONG_PORT=8000

# Where browsers reach the API (kong). Defaults to http://localhost:${KONG_PORT}.
# For a remote deploy set this to the host your browser will use, e.g.
#   PUBLIC_API_URL=https://uptime.example.com
PUBLIC_API_URL=http://localhost:8000

# Database
POSTGRES_PASSWORD=postgres

# JWT — must be >= 32 chars. ALL keys below must be regenerated together.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# Anon key (role=anon) signed with JWT_SECRET
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
# Service role key (role=service_role) signed with JWT_SECRET
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# Realtime cookie/session signing key. Regenerate with: openssl rand -base64 48
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq
